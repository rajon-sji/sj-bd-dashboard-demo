# Supabase (set automatically when linked via Vercel integration)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Vercel Supabase integration may also set this name (server-only is fine for API routes):
SUPABASE_ANON_KEY=

# Server-only — used for seed scripts and admin operations (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Database password — for local migrations only (npm run db:migrate)
SUPABASE_DB_PASSWORD=

# Optional — skip auto region detection for pooler connections
SUPABASE_REGION=us-east-1
SUPABASE_POOLER_PREFIX=aws-1

# Optional — paste Session pooler URI from Supabase dashboard (most reliable)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Google Gemini — reasoning + embeddings (https://aistudio.google.com/apikey)
GOOGLE_GENERATIVE_AI_API_KEY=
# Optional — defaults to gemini-2.5-flash (2.0-flash free tier is often exhausted)
GOOGLE_GENERATIVE_AI_MODEL=gemini-2.5-flash
